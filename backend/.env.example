# Copy this file to .env and fill in YOUR SQL Server details
PORT=3001
NODE_ENV=development

DB_SERVER=localhost
DB_PORT=1433
DB_NAME=SentinelDB
DB_USER=sa
DB_PASSWORD=YourPassword@123
DB_ENCRYPT=false
DB_TRUST_CERT=true

JWT_SECRET=your_strong_secret_here
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
SIM_DEFAULT_INTERVAL_MS=4000
