{
  "name": "sentinel-backend",
  "version": "1.0.0",
  "description": "Sentinel — Autonomous Rule Intelligence & Action System (SQL Server Edition)",
  "main": "src/app.js",
  "scripts": {
    "start":   "node src/app.js",
    "dev":     "nodemon src/app.js",
    "migrate": "node database/migrations/run.js",
    "seed":    "node database/seeds/run.js",
    "setup":   "npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "mssql":             "^11.0.1",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.18.3",
    "express-rate-limit":"^7.2.0",
    "express-validator": "^7.0.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "uuid":              "^9.0.1",
    "systeminformation": "^5.22.11"
  },
  "devDependencies": {
    "jest":    "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
